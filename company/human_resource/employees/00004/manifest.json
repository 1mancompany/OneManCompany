{
  "id": "ea-founding",
  "name": "Executive Assistant",
  "version": "1.0.0",
  "role": "EA",
  "hosting": "company",
  "settings": {
    "sections": [
      {
        "id": "agent_family",
        "title": "Agent Family",
        "fields": [
          {
            "key": "agent_family",
            "type": "select",
            "label": "Agent Family",
            "options": [
              {
                "value": "langchain",
                "label": "LangChain"
              },
              {
                "value": "claude",
                "label": "Claude Session"
              },
              {
                "value": "openclaw",
                "label": "OpenClaw"
              }
            ]
          }
        ]
      },
      {
        "id": "llm",
        "title": "LLM Configuration",
        "fields": [
          {
            "key": "llm_model",
            "type": "select",
            "label": "Model",
            "options_from": "api:models"
          },
          {
            "key": "temperature",
            "type": "number",
            "label": "Temperature",
            "default": 0.7,
            "min": 0,
            "max": 2,
            "step": 0.1
          }
        ]
      }
    ]
  },
  "prompts": {
    "skills": [
      "skills/*/SKILL.md"
    ]
  },
  "tools": {
    "builtin": [],
    "custom": []
  },
  "platform_capabilities": [
    "websocket"
  ]
}