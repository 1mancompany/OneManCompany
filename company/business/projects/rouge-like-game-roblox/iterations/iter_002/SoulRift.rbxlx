  <Item class="LocalScript" referent="11">
    <Properties>
      <string name="Name">ClientMain</string>
      <string name="Source"><![CDATA[--[[
	ClientMain.luau — Client bootstrap script
	StarterPlayerScripts/ClientMain (LocalScript)

	Initializes all client modules in correct order and shows
	the welcome/start screen with controls.
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer

-- Require client modules (they are ModuleScripts in StarterPlayerScripts)
local UIManager = require(script.Parent.UIManager)
local CombatClient = require(script.Parent.CombatClient)
local InputController = require(script.Parent.InputController)

-- Initialize in order: UI first (creates HUD), then combat VFX, then input
UIManager.init()
CombatClient.init()

-- InputController needs CombatHUD to exist for mobile binds, give a small delay
task.defer(function()
	InputController.init()
end)

--------------------------------------------------
-- Welcome / Start Run Screen
--------------------------------------------------

local function showWelcomeScreen()
	local gui = player:WaitForChild("PlayerGui")

	local screen = Instance.new("ScreenGui")
	screen.Name = "WelcomeScreen"
	screen.ResetOnSpawn = false
	screen.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screen.DisplayOrder = 10
	screen.Parent = gui

	-- Full background
	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.new(0.05, 0.02, 0.1)
	bg.BackgroundTransparency = 0.3
	bg.BorderSizePixel = 0
	bg.Parent = screen

	-- Title
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(0, 500, 0, 80)
	title.Position = UDim2.new(0.5, -250, 0.08, 0)
	title.BackgroundTransparency = 1
	title.Text = "SOUL RIFT"
	title.TextColor3 = Color3.new(1, 0.85, 0)
	title.Font = Enum.Font.GothamBold
	title.TextSize = 56
	title.Parent = screen

	local subtitle = Instance.new("TextLabel")
	subtitle.Size = UDim2.new(0, 500, 0, 30)
	subtitle.Position = UDim2.new(0.5, -250, 0.08, 80)
	subtitle.BackgroundTransparency = 1
	subtitle.Text = "Roguelike Action RPG"
	subtitle.TextColor3 = Color3.new(0.7, 0.7, 0.8)
	subtitle.Font = Enum.Font.Gotham
	subtitle.TextSize = 18
	subtitle.Parent = screen

	-- Controls panel
	local controlsPanel = Instance.new("Frame")
	controlsPanel.Size = UDim2.new(0, 420, 0, 320)
	controlsPanel.Position = UDim2.new(0.5, -210, 0.25, 0)
	controlsPanel.BackgroundColor3 = Color3.new(0.08, 0.08, 0.12)
	controlsPanel.BackgroundTransparency = 0.2
	controlsPanel.BorderSizePixel = 0
	controlsPanel.Parent = screen

	local panelCorner = Instance.new("UICorner")
	panelCorner.CornerRadius = UDim.new(0, 16)
	panelCorner.Parent = controlsPanel

	local panelStroke = Instance.new("UIStroke")
	panelStroke.Color = Color3.new(0.3, 0.25, 0.5)
	panelStroke.Thickness = 2
	panelStroke.Parent = controlsPanel

	local controlsTitle = Instance.new("TextLabel")
	controlsTitle.Size = UDim2.new(1, 0, 0, 35)
	controlsTitle.Position = UDim2.new(0, 0, 0, 10)
	controlsTitle.BackgroundTransparency = 1
	controlsTitle.Text = "CONTROLS"
	controlsTitle.TextColor3 = Color3.new(1, 0.85, 0)
	controlsTitle.Font = Enum.Font.GothamBold
	controlsTitle.TextSize = 20
	controlsTitle.Parent = controlsPanel

	local controls = {
		{ key = "W A S D", action = "Move" },
		{ key = "Mouse", action = "Look around" },
		{ key = "Q", action = "Skill 1 — Swift Slash" },
		{ key = "E", action = "Skill 2 — Sword Wave" },
		{ key = "R", action = "Skill 3 — Counter Dash" },
		{ key = "F", action = "Ultimate (when energy full)" },
		{ key = "Space", action = "Dodge (i-frames)" },
		{ key = "T", action = "Toggle auto-attack" },
	}

	for i, ctrl in ipairs(controls) do
		local row = Instance.new("Frame")
		row.Size = UDim2.new(1, -40, 0, 28)
		row.Position = UDim2.new(0, 20, 0, 45 + (i - 1) * 32)
		row.BackgroundTransparency = 1
		row.Parent = controlsPanel

		local keyLabel = Instance.new("TextLabel")
		keyLabel.Size = UDim2.new(0, 100, 1, 0)
		keyLabel.BackgroundColor3 = Color3.new(0.15, 0.15, 0.2)
		keyLabel.BackgroundTransparency = 0.3
		keyLabel.Text = ctrl.key
		keyLabel.TextColor3 = Color3.new(1, 1, 1)
		keyLabel.Font = Enum.Font.Code
		keyLabel.TextSize = 14
		keyLabel.Parent = row

		local keyCorner = Instance.new("UICorner")
		keyCorner.CornerRadius = UDim.new(0, 4)
		keyCorner.Parent = keyLabel

		local actionLabel = Instance.new("TextLabel")
		actionLabel.Size = UDim2.new(1, -115, 1, 0)
		actionLabel.Position = UDim2.new(0, 115, 0, 0)
		actionLabel.BackgroundTransparency = 1
		actionLabel.Text = ctrl.action
		actionLabel.TextColor3 = Color3.new(0.8, 0.8, 0.85)
		actionLabel.Font = Enum.Font.Gotham
		actionLabel.TextSize = 14
		actionLabel.TextXAlignment = Enum.TextXAlignment.Left
		actionLabel.Parent = row
	end

	-- Start Run Button
	local startBtn = Instance.new("TextButton")
	startBtn.Name = "StartRunButton"
	startBtn.Size = UDim2.new(0, 280, 0, 60)
	startBtn.Position = UDim2.new(0.5, -140, 0.82, 0)
	startBtn.BackgroundColor3 = Color3.new(0.2, 0.6, 0.9)
	startBtn.Text = "START DUNGEON RUN"
	startBtn.TextColor3 = Color3.new(1, 1, 1)
	startBtn.Font = Enum.Font.GothamBold
	startBtn.TextSize = 22
	startBtn.BorderSizePixel = 0
	startBtn.Parent = screen

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 12)
	btnCorner.Parent = startBtn

	local btnStroke = Instance.new("UIStroke")
	btnStroke.Color = Color3.new(0.4, 0.7, 1)
	btnStroke.Thickness = 2
	btnStroke.Parent = startBtn

	-- Pulse animation on button
	task.spawn(function()
		while startBtn.Parent do
			TweenService:Create(startBtn, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				BackgroundColor3 = Color3.new(0.3, 0.7, 1),
			}):Play()
			task.wait(0.8)
			if not startBtn.Parent then break end
			TweenService:Create(startBtn, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				BackgroundColor3 = Color3.new(0.2, 0.6, 0.9),
			}):Play()
			task.wait(0.8)
		end
	end)

	-- Start run on click
	local startRunEvent = ReplicatedStorage:WaitForChild("StartRunEvent", 10)

	startBtn.Activated:Connect(function()
		if startRunEvent then
			startRunEvent:FireServer()
		end
		-- Fade out welcome screen
		TweenService:Create(bg, TweenInfo.new(0.5), {
			BackgroundTransparency = 1,
		}):Play()
		for _, child in screen:GetDescendants() do
			if child:IsA("TextLabel") or child:IsA("TextButton") then
				TweenService:Create(child, TweenInfo.new(0.5), {
					TextTransparency = 1,
				}):Play()
			end
			if child:IsA("Frame") then
				TweenService:Create(child, TweenInfo.new(0.5), {
					BackgroundTransparency = 1,
				}):Play()
			end
			if child:IsA("UIStroke") then
				TweenService:Create(child, TweenInfo.new(0.5), {
					Transparency = 1,
				}):Play()
			end
		end
		task.delay(0.6, function()
			screen:Destroy()
		end)
	end)
end

--------------------------------------------------
-- Controls hint (persistent small overlay during gameplay)
--------------------------------------------------

local function showControlsHint()
	local gui = player:WaitForChild("PlayerGui")

	local screen = Instance.new("ScreenGui")
	screen.Name = "ControlsHint"
	screen.ResetOnSpawn = false
	screen.DisplayOrder = 5
	screen.Parent = gui

	local hint = Instance.new("TextLabel")
	hint.Size = UDim2.new(0, 350, 0, 25)
	hint.Position = UDim2.new(0.5, -175, 1, -25)
	hint.BackgroundTransparency = 1
	hint.Text = "Q/E/R: Skills | F: Ultimate | Space: Dodge | T: Auto-attack"
	hint.TextColor3 = Color3.new(0.6, 0.6, 0.65)
	hint.Font = Enum.Font.Gotham
	hint.TextSize = 11
	hint.Parent = screen

	-- Fade out after 30 seconds
	task.delay(30, function()
		if hint.Parent then
			TweenService:Create(hint, TweenInfo.new(2), {
				TextTransparency = 1,
			}):Play()
		end
	end)
end

--------------------------------------------------
-- Boot
--------------------------------------------------

-- Wait for character to load
player.CharacterAdded:Wait()
task.wait(1)

showWelcomeScreen()
showControlsHint()

print("[ClientMain] Soul Rift client initialized")
]]></string>
    </Properties>
  </Item>
  <Item class="ModuleScript" referent="12">
    <Properties>
      <string name="Name">CombatClient</string>
      <string name="Source"><![CDATA[--[[
	CombatClient.luau — Client-side combat visual effects
	StarterPlayerScripts/CombatClient

	Handles: damage numbers, hit effects, screen shake,
	skill VFX, health bar updates.
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local CombatClient = {}

--------------------------------------------------
-- Initialization
--------------------------------------------------

function CombatClient.init()
	local combatEvent = ReplicatedStorage:WaitForChild("CombatEvent", 10)
	if combatEvent then
		combatEvent.OnClientEvent:Connect(function(eventType, data)
			CombatClient._handleEvent(eventType, data)
		end)
	end
end

--------------------------------------------------
-- Event dispatcher
--------------------------------------------------

function CombatClient._handleEvent(eventType: string, data: any)
	if eventType == "DamageDealt" then
		CombatClient._showDamageNumber(data.target, data.damage, data.isCrit, false)
		CombatClient._updateEnemyHealthBar(data.target, data.targetHealth, data.targetMaxHealth)
		CombatClient._hitEffect(data.target)

	elseif eventType == "DamageTaken" then
		CombatClient._showDamageNumber(player.Character, data.damage, false, true)
		CombatClient._screenShake(0.3, 3)
		CombatClient._updatePlayerHUD(data.currentHealth, data.maxHealth)

	elseif eventType == "EnemyKilled" then
		CombatClient._deathEffect(data.target)
		CombatClient._showReward(data.xp, data.soulShards)

	elseif eventType == "Healed" then
		CombatClient._showHealNumber(data.amount)

	elseif eventType == "TalentCards" then
		CombatClient._showTalentPicker(data.cards)

	elseif eventType == "RoomCleared" then
		CombatClient._showRoomCleared()
	end
end

--------------------------------------------------
-- Damage numbers (floating text)
--------------------------------------------------

function CombatClient._showDamageNumber(target: Instance?, damage: number, isCrit: boolean, isPlayerDamage: boolean)
	if not target then return end

	local rootPart = nil
	if target:IsA("Model") then
		rootPart = target:FindFirstChild("HumanoidRootPart")
	end
	if not rootPart then return end

	local billboard = Instance.new("BillboardGui")
	billboard.Size = UDim2.new(0, 100, 0, 40)
	billboard.StudsOffset = Vector3.new(
		math.random(-3, 3),
		math.random(2, 5),
		math.random(-3, 3)
	)
	billboard.Adornee = rootPart
	billboard.AlwaysOnTop = true
	billboard.Parent = rootPart

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextScaled = true

	if isPlayerDamage then
		label.Text = "-" .. tostring(damage)
		label.TextColor3 = Color3.new(1, 0.2, 0.2)
	elseif isCrit then
		label.Text = tostring(damage) .. "!"
		label.TextColor3 = Color3.new(1, 0.85, 0)
		label.TextSize = 28
	else
		label.Text = tostring(damage)
		label.TextColor3 = Color3.new(1, 1, 1)
	end

	label.Parent = billboard

	-- Float up and fade
	local tween = TweenService:Create(billboard, TweenInfo.new(1.0, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		StudsOffset = billboard.StudsOffset + Vector3.new(0, 4, 0),
	})
	local fadeTween = TweenService:Create(label, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		TextTransparency = 1,
	})

	tween:Play()
	task.delay(0.3, function()
		fadeTween:Play()
	end)

	task.delay(1.2, function()
		billboard:Destroy()
	end)
end

--------------------------------------------------
-- Hit and death effects
--------------------------------------------------

function CombatClient._hitEffect(target: Instance?)
	if not target or not target:IsA("Model") then return end
	local rootPart = target:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	-- Flash white briefly
	local originalColor = rootPart.Color
	rootPart.Color = Color3.new(1, 1, 1)
	task.delay(0.1, function()
		if rootPart.Parent then
			rootPart.Color = originalColor
		end
	end)

	-- Hit particle
	local attachment = Instance.new("Attachment")
	attachment.Parent = rootPart

	local particles = Instance.new("ParticleEmitter")
	particles.Color = ColorSequence.new(Color3.new(1, 0.5, 0))
	particles.Size = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0) })
	particles.Lifetime = NumberRange.new(0.2, 0.4)
	particles.Speed = NumberRange.new(10, 20)
	particles.Rate = 0
	particles.SpreadAngle = Vector2.new(180, 180)
	particles.Parent = attachment

	particles:Emit(8)
	task.delay(0.5, function()
		attachment:Destroy()
	end)
end

function CombatClient._deathEffect(target: Instance?)
	if not target or not target:IsA("Model") then return end

	-- Fade out all parts
	for _, part in target:GetDescendants() do
		if part:IsA("BasePart") then
			local tween = TweenService:Create(part, TweenInfo.new(0.5), {
				Transparency = 1,
			})
			tween:Play()
		end
	end

	-- Soul particles rising
	local rootPart = target:FindFirstChild("HumanoidRootPart")
	if rootPart then
		local attachment = Instance.new("Attachment")
		attachment.Parent = rootPart

		local particles = Instance.new("ParticleEmitter")
		particles.Color = ColorSequence.new(Color3.new(0.5, 0.8, 1))
		particles.Size = NumberSequence.new({ NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 0) })
		particles.Lifetime = NumberRange.new(0.5, 1.0)
		particles.Speed = NumberRange.new(5, 15)
		particles.Rate = 0
		particles.SpreadAngle = Vector2.new(30, 30)
		particles.EmissionDirection = Enum.NormalId.Top
		particles.Parent = attachment

		particles:Emit(15)
		task.delay(1.5, function()
			attachment:Destroy()
		end)
	end
end

--------------------------------------------------
-- Screen effects
--------------------------------------------------

function CombatClient._screenShake(duration: number, intensity: number)
	local camera = workspace.CurrentCamera
	if not camera then return end

	local startTime = tick()
	local originalCFrame = camera.CFrame

	local conn
	conn = game:GetService("RunService").RenderStepped:Connect(function()
		local elapsed = tick() - startTime
		if elapsed >= duration then
			conn:Disconnect()
			return
		end

		local factor = 1 - (elapsed / duration)
		local offset = Vector3.new(
			(math.random() - 0.5) * intensity * factor,
			(math.random() - 0.5) * intensity * factor,
			0
		)
		camera.CFrame = camera.CFrame * CFrame.new(offset)
	end)
end

--------------------------------------------------
-- HUD updates
--------------------------------------------------

function CombatClient._updatePlayerHUD(currentHealth: number, maxHealth: number)
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local hud = gui:FindFirstChild("CombatHUD")
	if not hud then return end

	local healthBar = hud:FindFirstChild("HealthBarFill", true)
	if healthBar then
		local pct = math.clamp(currentHealth / maxHealth, 0, 1)
		TweenService:Create(healthBar, TweenInfo.new(0.3), {
			Size = UDim2.new(pct, 0, 1, 0),
		}):Play()

		-- Color change based on health
		if pct <= 0.25 then
			healthBar.BackgroundColor3 = Color3.new(0.8, 0.1, 0.1)
		elseif pct <= 0.5 then
			healthBar.BackgroundColor3 = Color3.new(0.9, 0.6, 0.1)
		else
			healthBar.BackgroundColor3 = Color3.new(0.2, 0.8, 0.2)
		end
	end

	local healthText = hud:FindFirstChild("HealthText", true)
	if healthText then
		healthText.Text = tostring(math.floor(currentHealth)) .. " / " .. tostring(math.floor(maxHealth))
	end
end

function CombatClient._updateEnemyHealthBar(enemyModel: Instance?, currentHealth: number, maxHealth: number)
	if not enemyModel or not enemyModel:IsA("Model") then return end

	local healthBar = enemyModel:FindFirstChild("HealthBar", true)
	if not healthBar then return end

	local fill = healthBar:FindFirstChild("Fill", true)
	if fill then
		local pct = math.clamp(currentHealth / maxHealth, 0, 1)
		fill.Size = UDim2.new(pct, 0, 1, 0)
	end
end

--------------------------------------------------
-- UI popups
--------------------------------------------------

function CombatClient._showReward(xp: number, soulShards: number)
	-- Simple floating text at screen center
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local screen = gui:FindFirstChild("CombatHUD") or gui:FindFirstChildOfClass("ScreenGui")
	if not screen then return end

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 300, 0, 40)
	label.Position = UDim2.new(0.5, -150, 0.4, 0)
	label.BackgroundTransparency = 1
	label.Text = string.format("+%d XP  +%d Soul Shards", xp, soulShards)
	label.TextColor3 = Color3.new(1, 0.85, 0)
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.Parent = screen

	TweenService:Create(label, TweenInfo.new(2.0, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.5, -150, 0.3, 0),
		TextTransparency = 1,
	}):Play()

	task.delay(2.5, function()
		label:Destroy()
	end)
end

function CombatClient._showHealNumber(amount: number)
	local character = player.Character
	if not character then return end

	CombatClient._showDamageNumber(character, amount, false, false)
end

function CombatClient._showRoomCleared()
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local screen = gui:FindFirstChild("CombatHUD") or gui:FindFirstChildOfClass("ScreenGui")
	if not screen then return end

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 400, 0, 60)
	label.Position = UDim2.new(0.5, -200, 0.35, 0)
	label.BackgroundTransparency = 1
	label.Text = "ROOM CLEARED"
	label.TextColor3 = Color3.new(0.2, 1, 0.4)
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.TextStrokeTransparency = 0.5
	label.Parent = screen

	TweenService:Create(label, TweenInfo.new(1.5), {
		TextTransparency = 1,
		TextStrokeTransparency = 1,
	}):Play()

	task.delay(2.0, function()
		label:Destroy()
	end)
end

function CombatClient._showTalentPicker(cards: { any })
	-- Talent card selection is handled by UIManager
	-- This just forwards the data
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local uiManager = gui:FindFirstChild("UIManagerScript")
	if uiManager then
		uiManager:SetAttribute("TalentCards", game:GetService("HttpService"):JSONEncode(cards))
	end
end

return CombatClient
]]></string>
    </Properties>
  </Item>
  <Item class="ModuleScript" referent="13">
    <Properties>
      <string name="Name">InputController</string>
      <string name="Source"><![CDATA[--[[
	InputController.luau — Player input handling (PC + Mobile)
	StarterPlayerScripts/InputController

	Handles: movement, skill buttons, dodge, auto-attack toggle.
	Sends actions to server via RemoteEvents.
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local ContextActionService = game:GetService("ContextActionService")

local player = Players.LocalPlayer
local InputController = {}

-- Remote events (created by GameManager)
local skillEvent: RemoteEvent = nil
local dodgeEvent: RemoteEvent = nil
local ultimateEvent: RemoteEvent = nil

-- State
local autoAttack = true
local autoAttackTimer = 0
local AUTO_ATTACK_INTERVAL = 0.5

--------------------------------------------------
-- Initialization
--------------------------------------------------

function InputController.init()
	-- Wait for remote events
	skillEvent = ReplicatedStorage:WaitForChild("SkillEvent", 10)
	dodgeEvent = ReplicatedStorage:WaitForChild("DodgeEvent", 10)
	ultimateEvent = ReplicatedStorage:WaitForChild("UltimateEvent", 10)

	-- PC keyboard bindings
	InputController._bindKeyboard()

	-- Mobile touch buttons (created by UIManager)
	InputController._bindMobile()

	-- Auto-attack loop
	RunService.Heartbeat:Connect(function(dt)
		InputController._updateAutoAttack(dt)
	end)
end

--------------------------------------------------
-- Keyboard bindings (PC)
--------------------------------------------------

function InputController._bindKeyboard()
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end

		if input.KeyCode == Enum.KeyCode.Q then
			InputController.useSkill(1)
		elseif input.KeyCode == Enum.KeyCode.E then
			InputController.useSkill(2)
		elseif input.KeyCode == Enum.KeyCode.R then
			InputController.useSkill(3)
		elseif input.KeyCode == Enum.KeyCode.F then
			InputController.useUltimate()
		elseif input.KeyCode == Enum.KeyCode.Space then
			InputController.dodge()
		elseif input.KeyCode == Enum.KeyCode.T then
			autoAttack = not autoAttack
		end
	end)
end

--------------------------------------------------
-- Mobile bindings
--------------------------------------------------

function InputController._bindMobile()
	-- Touch buttons are handled by UIManager
	-- This connects to the button events
	local gui = player:WaitForChild("PlayerGui", 10)
	if not gui then return end

	local combatUI = gui:WaitForChild("CombatHUD", 10)
	if not combatUI then return end

	local function connectButton(name: string, callback: () -> ())
		local btn = combatUI:FindFirstChild(name, true)
		if btn and btn:IsA("GuiButton") then
			btn.Activated:Connect(callback)
		end
	end

	connectButton("Skill1Button", function() InputController.useSkill(1) end)
	connectButton("Skill2Button", function() InputController.useSkill(2) end)
	connectButton("Skill3Button", function() InputController.useSkill(3) end)
	connectButton("UltimateButton", function() InputController.useUltimate() end)
	connectButton("DodgeButton", function() InputController.dodge() end)
end

--------------------------------------------------
-- Actions
--------------------------------------------------

function InputController.useSkill(index: number)
	if skillEvent then
		skillEvent:FireServer(index)
	end
end

function InputController.useUltimate()
	if ultimateEvent then
		ultimateEvent:FireServer()
	end
end

function InputController.dodge()
	if dodgeEvent then
		dodgeEvent:FireServer()
	end

	-- Client-side dodge movement (responsive feel, server validates)
	local character = player.Character
	if not character then return end
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	local moveDir = character.Humanoid.MoveDirection
	if moveDir.Magnitude < 0.1 then
		moveDir = rootPart.CFrame.LookVector
	end

	-- Quick dash effect
	local dodgeDist = 20
	local bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(50000, 0, 50000)
	bodyVelocity.Velocity = moveDir.Unit * dodgeDist / 0.3
	bodyVelocity.Parent = rootPart

	task.delay(0.3, function()
		if bodyVelocity.Parent then
			bodyVelocity:Destroy()
		end
	end)
end

--------------------------------------------------
-- Auto-attack
--------------------------------------------------

function InputController._updateAutoAttack(dt: number)
	if not autoAttack then return end

	autoAttackTimer -= dt
	if autoAttackTimer > 0 then return end
	autoAttackTimer = AUTO_ATTACK_INTERVAL

	-- Find nearest enemy in range
	local character = player.Character
	if not character or not character:FindFirstChild("HumanoidRootPart") then
		return
	end

	local pos = character.HumanoidRootPart.Position
	local attackRange = 10 -- default melee range

	local nearestEnemy = nil
	local nearestDist = attackRange

	for _, obj in workspace:GetChildren() do
		if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= character then
			local hrp = obj:FindFirstChild("HumanoidRootPart")
			if hrp then
				local dist = (hrp.Position - pos).Magnitude
				if dist < nearestDist then
					nearestEnemy = obj
					nearestDist = dist
				end
			end
		end
	end

	if nearestEnemy and skillEvent then
		-- Auto-attack uses skill slot 1 (basic attack)
		skillEvent:FireServer(1, nearestEnemy)
	end
end

--------------------------------------------------
-- Target aiming (mouse/touch)
--------------------------------------------------

function InputController.getAimPosition(): Vector3?
	local mouse = player:GetMouse()
	if mouse then
		return mouse.Hit.Position
	end
	return nil
end

return InputController
]]></string>
    </Properties>
  </Item>
  <Item class="ModuleScript" referent="14">
    <Properties>
      <string name="Name">UIManager</string>
      <string name="Source"><![CDATA[--[[
	UIManager.luau — UI creation and management
	StarterPlayerScripts/UIManager

	Creates: Combat HUD, talent card picker, room transition screen,
	death screen, results screen.
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local UIManager = {}

--------------------------------------------------
-- Initialization
--------------------------------------------------

function UIManager.init()
	UIManager._createCombatHUD()

	-- Listen for talent card events
	local combatEvent = ReplicatedStorage:WaitForChild("CombatEvent", 10)
	if combatEvent then
		combatEvent.OnClientEvent:Connect(function(eventType, data)
			if eventType == "TalentCards" then
				UIManager.showTalentPicker(data.cards)
			elseif eventType == "RunComplete" then
				UIManager.showResultsScreen(data)
			elseif eventType == "PlayerDied" then
				UIManager.showDeathScreen()
			elseif eventType == "RoomTransition" then
				UIManager.showRoomTransition(data.roomType, data.roomIndex)
			end
		end)
	end
end

--------------------------------------------------
-- Combat HUD
--------------------------------------------------

function UIManager._createCombatHUD()
	local gui = player:WaitForChild("PlayerGui")

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "CombatHUD"
	screenGui.ResetOnSpawn = false
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.Parent = gui

	-- Health bar
	UIManager._createHealthBar(screenGui)

	-- Energy bar
	UIManager._createEnergyBar(screenGui)

	-- Skill buttons
	UIManager._createSkillButtons(screenGui)

	-- Room info
	UIManager._createRoomInfo(screenGui)

	-- Minimap placeholder
	UIManager._createMinimap(screenGui)
end

function UIManager._createHealthBar(parent: ScreenGui)
	local container = Instance.new("Frame")
	container.Name = "HealthBarContainer"
	container.Size = UDim2.new(0, 250, 0, 25)
	container.Position = UDim2.new(0, 20, 0, 20)
	container.BackgroundColor3 = Color3.new(0.15, 0.15, 0.15)
	container.BorderSizePixel = 0
	container.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = container

	local fill = Instance.new("Frame")
	fill.Name = "HealthBarFill"
	fill.Size = UDim2.new(1, 0, 1, 0)
	fill.BackgroundColor3 = Color3.new(0.2, 0.8, 0.2)
	fill.BorderSizePixel = 0
	fill.Parent = container

	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(0, 6)
	fillCorner.Parent = fill

	local text = Instance.new("TextLabel")
	text.Name = "HealthText"
	text.Size = UDim2.new(1, 0, 1, 0)
	text.BackgroundTransparency = 1
	text.Text = "100 / 100"
	text.TextColor3 = Color3.new(1, 1, 1)
	text.Font = Enum.Font.GothamBold
	text.TextSize = 14
	text.Parent = container
end

function UIManager._createEnergyBar(parent: ScreenGui)
	local container = Instance.new("Frame")
	container.Name = "EnergyBarContainer"
	container.Size = UDim2.new(0, 250, 0, 12)
	container.Position = UDim2.new(0, 20, 0, 50)
	container.BackgroundColor3 = Color3.new(0.15, 0.15, 0.15)
	container.BorderSizePixel = 0
	container.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 4)
	corner.Parent = container

	local fill = Instance.new("Frame")
	fill.Name = "EnergyBarFill"
	fill.Size = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3 = Color3.new(0.3, 0.5, 1)
	fill.BorderSizePixel = 0
	fill.Parent = container

	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(0, 4)
	fillCorner.Parent = fill
end

function UIManager._createSkillButtons(parent: ScreenGui)
	local container = Instance.new("Frame")
	container.Name = "SkillBar"
	container.Size = UDim2.new(0, 350, 0, 70)
	container.Position = UDim2.new(0.5, -175, 1, -90)
	container.BackgroundTransparency = 1
	container.Parent = parent

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Padding = UDim.new(0, 8)
	layout.Parent = container

	local buttonDefs = {
		{ name = "Skill1Button", label = "Q", color = Color3.new(0.3, 0.6, 0.9) },
		{ name = "Skill2Button", label = "E", color = Color3.new(0.9, 0.4, 0.3) },
		{ name = "Skill3Button", label = "R", color = Color3.new(0.4, 0.8, 0.4) },
		{ name = "DodgeButton",  label = "⚡", color = Color3.new(0.9, 0.85, 0.3) },
		{ name = "UltimateButton", label = "F", color = Color3.new(0.8, 0.3, 0.9) },
	}

	for _, def in buttonDefs do
		local btn = Instance.new("TextButton")
		btn.Name = def.name
		btn.Size = UDim2.new(0, 60, 0, 60)
		btn.BackgroundColor3 = def.color
		btn.Text = def.label
		btn.TextColor3 = Color3.new(1, 1, 1)
		btn.Font = Enum.Font.GothamBold
		btn.TextSize = 22
		btn.BorderSizePixel = 0
		btn.Parent = container

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 10)
		corner.Parent = btn

		-- Cooldown overlay
		local cdOverlay = Instance.new("Frame")
		cdOverlay.Name = "CooldownOverlay"
		cdOverlay.Size = UDim2.new(1, 0, 0, 0)
		cdOverlay.Position = UDim2.new(0, 0, 1, 0)
		cdOverlay.AnchorPoint = Vector2.new(0, 1)
		cdOverlay.BackgroundColor3 = Color3.new(0, 0, 0)
		cdOverlay.BackgroundTransparency = 0.5
		cdOverlay.BorderSizePixel = 0
		cdOverlay.Parent = btn

		local cdCorner = Instance.new("UICorner")
		cdCorner.CornerRadius = UDim.new(0, 10)
		cdCorner.Parent = cdOverlay
	end
end

function UIManager._createRoomInfo(parent: ScreenGui)
	local label = Instance.new("TextLabel")
	label.Name = "RoomInfo"
	label.Size = UDim2.new(0, 200, 0, 30)
	label.Position = UDim2.new(1, -220, 0, 20)
	label.BackgroundTransparency = 1
	label.Text = "Room 1 / 10"
	label.TextColor3 = Color3.new(1, 1, 1)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 18
	label.TextXAlignment = Enum.TextXAlignment.Right
	label.Parent = parent
end

function UIManager._createMinimap(parent: ScreenGui)
	local frame = Instance.new("Frame")
	frame.Name = "Minimap"
	frame.Size = UDim2.new(0, 120, 0, 120)
	frame.Position = UDim2.new(1, -140, 0, 55)
	frame.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
	frame.BackgroundTransparency = 0.3
	frame.BorderSizePixel = 0
	frame.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = frame

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = "MINIMAP"
	label.TextColor3 = Color3.new(0.5, 0.5, 0.5)
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.Parent = frame
end

--------------------------------------------------
-- Talent Card Picker
--------------------------------------------------

function UIManager.showTalentPicker(cards: { any })
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local screen = Instance.new("ScreenGui")
	screen.Name = "TalentPicker"
	screen.Parent = gui

	-- Darken background
	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.new(0, 0, 0)
	bg.BackgroundTransparency = 0.5
	bg.Parent = screen

	-- Title
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(0, 400, 0, 50)
	title.Position = UDim2.new(0.5, -200, 0.15, 0)
	title.BackgroundTransparency = 1
	title.Text = "Choose a Talent Card"
	title.TextColor3 = Color3.new(1, 0.85, 0)
	title.Font = Enum.Font.GothamBold
	title.TextSize = 28
	title.Parent = screen

	-- Card container
	local cardContainer = Instance.new("Frame")
	cardContainer.Size = UDim2.new(0, 600, 0, 300)
	cardContainer.Position = UDim2.new(0.5, -300, 0.3, 0)
	cardContainer.BackgroundTransparency = 1
	cardContainer.Parent = screen

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Padding = UDim.new(0, 20)
	layout.Parent = cardContainer

	local rarityColors = {
		common = Color3.new(0.7, 0.7, 0.7),
		rare = Color3.new(0.3, 0.5, 1),
		epic = Color3.new(0.6, 0.2, 0.8),
		legendary = Color3.new(1, 0.75, 0),
	}

	local talentEvent = ReplicatedStorage:FindFirstChild("TalentSelectEvent")

	for i, card in cards do
		local cardFrame = Instance.new("TextButton")
		cardFrame.Name = "Card_" .. i
		cardFrame.Size = UDim2.new(0, 170, 0, 280)
		cardFrame.BackgroundColor3 = Color3.new(0.12, 0.12, 0.15)
		cardFrame.BorderSizePixel = 0
		cardFrame.Text = ""
		cardFrame.Parent = cardContainer

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 12)
		corner.Parent = cardFrame

		local stroke = Instance.new("UIStroke")
		stroke.Color = rarityColors[card.rarity] or Color3.new(0.5, 0.5, 0.5)
		stroke.Thickness = 3
		stroke.Parent = cardFrame

		-- Rarity label
		local rarityLabel = Instance.new("TextLabel")
		rarityLabel.Size = UDim2.new(1, -20, 0, 25)
		rarityLabel.Position = UDim2.new(0, 10, 0, 10)
		rarityLabel.BackgroundTransparency = 1
		rarityLabel.Text = card.rarity:upper()
		rarityLabel.TextColor3 = rarityColors[card.rarity] or Color3.new(1, 1, 1)
		rarityLabel.Font = Enum.Font.GothamBold
		rarityLabel.TextSize = 12
		rarityLabel.TextXAlignment = Enum.TextXAlignment.Left
		rarityLabel.Parent = cardFrame

		-- Card name
		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(1, -20, 0, 40)
		nameLabel.Position = UDim2.new(0, 10, 0, 45)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = card.name
		nameLabel.TextColor3 = Color3.new(1, 1, 1)
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextSize = 18
		nameLabel.TextWrapped = true
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.Parent = cardFrame

		-- Description
		local descLabel = Instance.new("TextLabel")
		descLabel.Size = UDim2.new(1, -20, 0, 120)
		descLabel.Position = UDim2.new(0, 10, 0, 100)
		descLabel.BackgroundTransparency = 1
		descLabel.Text = card.description
		descLabel.TextColor3 = Color3.new(0.8, 0.8, 0.8)
		descLabel.Font = Enum.Font.Gotham
		descLabel.TextSize = 14
		descLabel.TextWrapped = true
		descLabel.TextXAlignment = Enum.TextXAlignment.Left
		descLabel.TextYAlignment = Enum.TextYAlignment.Top
		descLabel.Parent = cardFrame

		-- Select button area
		cardFrame.Activated:Connect(function()
			if talentEvent then
				talentEvent:FireServer(card.id)
			end
			screen:Destroy()
		end)

		-- Hover effect
		cardFrame.MouseEnter:Connect(function()
			TweenService:Create(cardFrame, TweenInfo.new(0.2), {
				Size = UDim2.new(0, 180, 0, 290),
			}):Play()
		end)
		cardFrame.MouseLeave:Connect(function()
			TweenService:Create(cardFrame, TweenInfo.new(0.2), {
				Size = UDim2.new(0, 170, 0, 280),
			}):Play()
		end)
	end

	-- Auto-close after timeout
	task.delay(30, function()
		if screen.Parent then
			-- Auto-select first card
			if talentEvent and #cards > 0 then
				talentEvent:FireServer(cards[1].id)
			end
			screen:Destroy()
		end
	end)
end

--------------------------------------------------
-- Room transition
--------------------------------------------------

function UIManager.showRoomTransition(roomType: string, roomIndex: number)
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local combatHUD = gui:FindFirstChild("CombatHUD")
	if combatHUD then
		local roomInfo = combatHUD:FindFirstChild("RoomInfo")
		if roomInfo then
			roomInfo.Text = string.format("Room %d — %s", roomIndex, roomType:upper())
		end
	end

	-- Brief flash overlay
	local screen = Instance.new("ScreenGui")
	screen.Name = "TransitionOverlay"
	screen.Parent = gui

	local overlay = Instance.new("Frame")
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3 = Color3.new(0, 0, 0)
	overlay.BackgroundTransparency = 0
	overlay.Parent = screen

	TweenService:Create(overlay, TweenInfo.new(1.0, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 1,
	}):Play()

	task.delay(1.5, function()
		screen:Destroy()
	end)
end

--------------------------------------------------
-- Death and results screens
--------------------------------------------------

function UIManager.showDeathScreen()
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local screen = Instance.new("ScreenGui")
	screen.Name = "DeathScreen"
	screen.Parent = gui

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.new(0.3, 0, 0)
	bg.BackgroundTransparency = 0.4
	bg.Parent = screen

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 400, 0, 80)
	label.Position = UDim2.new(0.5, -200, 0.35, 0)
	label.BackgroundTransparency = 1
	label.Text = "YOU DIED"
	label.TextColor3 = Color3.new(0.8, 0.1, 0.1)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 48
	label.Parent = screen

	task.delay(3, function()
		if screen.Parent then
			screen:Destroy()
		end
	end)
end

function UIManager.showResultsScreen(data: any)
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local screen = Instance.new("ScreenGui")
	screen.Name = "ResultsScreen"
	screen.Parent = gui

	local bg = Instance.new("Frame")
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.new(0, 0, 0)
	bg.BackgroundTransparency = 0.3
	bg.Parent = screen

	local panel = Instance.new("Frame")
	panel.Size = UDim2.new(0, 400, 0, 350)
	panel.Position = UDim2.new(0.5, -200, 0.2, 0)
	panel.BackgroundColor3 = Color3.new(0.12, 0.12, 0.15)
	panel.BorderSizePixel = 0
	panel.Parent = screen

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 16)
	corner.Parent = panel

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 0, 50)
	title.BackgroundTransparency = 1
	title.Text = data.cleared and "RUN COMPLETE!" or "RUN OVER"
	title.TextColor3 = data.cleared and Color3.new(0.2, 1, 0.4) or Color3.new(1, 0.3, 0.3)
	title.Font = Enum.Font.GothamBold
	title.TextSize = 28
	title.Parent = panel

	local stats = {
		{ "Rooms Cleared", tostring(data.roomsCleared or 0) },
		{ "Enemies Defeated", tostring(data.enemiesKilled or 0) },
		{ "XP Earned", tostring(data.xpEarned or 0) },
		{ "Soul Shards", tostring(data.soulShards or 0) },
		{ "Time", string.format("%d:%02d", math.floor((data.duration or 0) / 60), math.floor((data.duration or 0) % 60)) },
	}

	for i, stat in stats do
		local row = Instance.new("Frame")
		row.Size = UDim2.new(1, -40, 0, 35)
		row.Position = UDim2.new(0, 20, 0, 60 + (i - 1) * 40)
		row.BackgroundTransparency = 1
		row.Parent = panel

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(0.6, 0, 1, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = stat[1]
		nameLabel.TextColor3 = Color3.new(0.7, 0.7, 0.7)
		nameLabel.Font = Enum.Font.Gotham
		nameLabel.TextSize = 16
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.Parent = row

		local valueLabel = Instance.new("TextLabel")
		valueLabel.Size = UDim2.new(0.4, 0, 1, 0)
		valueLabel.Position = UDim2.new(0.6, 0, 0, 0)
		valueLabel.BackgroundTransparency = 1
		valueLabel.Text = stat[2]
		valueLabel.TextColor3 = Color3.new(1, 0.85, 0)
		valueLabel.Font = Enum.Font.GothamBold
		valueLabel.TextSize = 18
		valueLabel.TextXAlignment = Enum.TextXAlignment.Right
		valueLabel.Parent = row
	end

	-- Return to hub button
	local returnBtn = Instance.new("TextButton")
	returnBtn.Size = UDim2.new(0, 200, 0, 45)
	returnBtn.Position = UDim2.new(0.5, -100, 1, -60)
	returnBtn.BackgroundColor3 = Color3.new(0.3, 0.6, 0.9)
	returnBtn.Text = "Return to Hub"
	returnBtn.TextColor3 = Color3.new(1, 1, 1)
	returnBtn.Font = Enum.Font.GothamBold
	returnBtn.TextSize = 18
	returnBtn.BorderSizePixel = 0
	returnBtn.Parent = panel

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 8)
	btnCorner.Parent = returnBtn

	returnBtn.Activated:Connect(function()
		local returnEvent = ReplicatedStorage:FindFirstChild("ReturnToHubEvent")
		if returnEvent then
			returnEvent:FireServer()
		end
		screen:Destroy()
	end)
end

--------------------------------------------------
-- Energy bar update
--------------------------------------------------

function UIManager.updateEnergyBar(current: number, max: number)
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return end

	local hud = gui:FindFirstChild("CombatHUD")
	if not hud then return end

	local fill = hud:FindFirstChild("EnergyBarFill", true)
	if fill then
		local pct = math.clamp(current / max, 0, 1)
		TweenService:Create(fill, TweenInfo.new(0.2), {
			Size = UDim2.new(pct, 0, 1, 0),
		}):Play()

		-- Glow when full
		if pct >= 1 then
			fill.BackgroundColor3 = Color3.new(0.5, 0.7, 1)
		else
			fill.BackgroundColor3 = Color3.new(0.3, 0.5, 1)
		end
	end
end

return UIManager
