{
  "name": "SoulRift",
  "tree": {
    "$className": "DataModel",

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/ServerScriptService"
    },

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/ReplicatedStorage/Shared"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true
      },
      "SpawnLocation": {
        "$className": "SpawnLocation",
        "$properties": {
          "Anchored": true,
          "Size": [8, 1, 8],
          "Position": [0, 0.5, 100]
        }
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Locked": true,
          "Size": [512, 20, 512],
          "Position": [0, -10, 0],
          "Color": [0.388, 0.372, 0.384],
          "Material": "Slate"
        }
      }
    },

    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Brightness": 2,
        "Technology": "ShadowMap"
      }
    },

    "SoundService": {
      "$className": "SoundService"
    },

    "Chat": {
      "$className": "Chat"
    },

    "Players": {
      "$className": "Players"
    },

    "ReplicatedFirst": {
      "$className": "ReplicatedFirst"
    },

    "ServerStorage": {
      "$className": "ServerStorage"
    },

    "StarterGui": {
      "$className": "StarterGui"
    },

    "StarterPack": {
      "$className": "StarterPack"
    }
  }
}
